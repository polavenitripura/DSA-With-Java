class Solution {
    public int[] bubbleSort(int[] nums) {
       int n=nums.length;
       for(int i=0;i<=n-1;i++){
        for(int j=i;j<=n-1;j++){
            if(nums[i]>nums[j]){
                int temp=nums[j];
                nums[j]=nums[i];
                nums[i]=temp;
            }
        }
       }
       return nums;
    }
}
