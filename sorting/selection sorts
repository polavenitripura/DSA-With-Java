class Solution {
    public int[] selectionSort(int[] nums) {
        int n=nums.length;
    for(int i=0;i<=n-2;i++){
        int mini=i;
        for(int j=i;j<=n-1;j++){
            if(nums[j]<nums[mini]){
                mini=j;
            }
            

        }
if(mini!=i){
    int temp=nums[i];
    nums[i]=nums[mini];
    nums[mini]=temp;
}   
 }
 return nums;
    }
}
