class Solution {
    public boolean isIsomorphic(String s, String t) {
        int n[]=new int[256];
        int m[]=new int[256];
        for(int i=0;i<s.length();i++){
            if(n[s.charAt(i)]!=m[t.charAt(i)]){
                return false;
            }
            n[s.charAt(i)]=i+1;
            m[t.charAt(i)]=i+1;
        }
        return true;
    }
}
